---
import PlaceholderPortrait from '@assets/team-members/profile.svg';
import RebeccaPortrait from '@assets/team-members/rebecca-portrait.jpeg';
import { Image } from 'astro:assets';

const members = [
  {
    image: PlaceholderPortrait,
    job: '',
    name: 'Nika',
  },
  {
    image: PlaceholderPortrait,
    job: '',
    name: 'Lena',
  },
  {
    image: RebeccaPortrait,
    job: '',
    name: 'Rebecca',
  },
  {
    image: PlaceholderPortrait,
    job: '',
    name: 'Anton',
  },
];
---

<section class="bg-light-green py-14 lg:py-20">
  <div class="mx-auto max-w-[80rem] px-5 lg:px-20">
    <h1 class="font-serif text-3xl font-bold">Das Team</h1>
    <div class="mt-14 grid grid-cols-2 gap-x-5 gap-y-14 lg:grid-cols-4 lg:gap-x-24">
      {
        members.map((member) => (
          <div class="flex flex-col items-center">
            <Image
              alt={member.name}
              class="aspect-square h-auto w-full rounded-full bg-white object-cover object-center"
              src={member.image}
            />
            <h2 class="mt-6 font-sans font-bold lg:mt-5 lg:text-xl">{member.name}</h2>
            <p class="lg:mt-3">{member.job}</p>
          </div>
        ))
      }
    </div>
    <p class="pt-4 italic">Das ist nur der Vereinsvorstand. Zum Team gehören noch viele mehr.</p>
  </div>
</section>
